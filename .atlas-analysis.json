  "keyFeatures": [
    "Dual-role authentication (student and company accounts)",
    "Job feed with filters by type, modality, salary range, and recency",
    "Student and company profile management",
    "Job application tracking with status updates",
    "Company job posting for empresa-role accounts",
    "Printable CV export via browser print dialog",
    "Auto-seeded SQLite database with 14 sample job listings",
    "Single-command dev startup via concurrently (frontend + backend)"
  ],
  "publicApiSurface": [
    "POST /api/login",
    "GET /api/jobs",
    "GET /api/jobs/:id",
    "POST /api/jobs",
    "GET /api/profile/student",
    "PUT /api/profile/student",
    "GET /api/profile/company",
    "PUT /api/profile/company",
    "GET /api/applications",
    "POST /api/applications",
    "login(email, password)",
    "getJobs()",
    "getJob(id)",
    "createJob(job, role)",
    "getStudentProfile()",
    "updateStudentProfile(patch)",
    "getCompanyProfile()",
    "updateCompanyProfile(patch)",
    "getApplications()",
    "applyToJob(jobId)"
  ]
